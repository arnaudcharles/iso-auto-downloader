{
    "version": "__VERSION__",
    "description": "Checks for and downloads the latest ISOs for Linux, Windows, and diagnostic tools, with checksum verification",
    "homepage": "https://github.com/arnaudcharles/iso-auto-downloader",
    "license": "GPL-2.0-or-later",
    "architecture": {
        "64bit": {
            "url": "https://github.com/arnaudcharles/iso-auto-downloader/releases/download/v__VERSION__/iso-auto-downloader___VERSION___windows_amd64.zip",
            "hash": "__SHA256_AMD64__"
        },
        "arm64": {
            "url": "https://github.com/arnaudcharles/iso-auto-downloader/releases/download/v__VERSION__/iso-auto-downloader___VERSION___windows_arm64.zip",
            "hash": "__SHA256_ARM64__"
        }
    },
    "bin": "iso-auto-downloader.exe",
    "shortcuts": [
        [
            "iso-auto-downloader.exe",
            "ISO Auto Downloader"
        ]
    ],
    "checkver": {
        "url": "https://github.com/arnaudcharles/iso-auto-downloader/releases",
        "regex": "/releases/tag/v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/arnaudcharles/iso-auto-downloader/releases/download/v$version/iso-auto-downloader_$version_windows_amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/arnaudcharles/iso-auto-downloader/releases/download/v$version/iso-auto-downloader_$version_windows_arm64.zip"
            }
        }
    }
}
